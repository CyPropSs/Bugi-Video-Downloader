{
  "manifest_version": 3,
  "name": "1Bugi Video Downloader",
  "version": "2.1.0",
  "description": "Simple Video Downloader",
  "permissions": [
    "storage",
    "tabs",
    "downloads",
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "webRequest",
    "power",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "bugi_kafa.png",
    "48": "bugi_kafa.png",
    "128": "bugi_kafa.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sounds/*.mp3",
        "sounds/*.ogg",
        "sounds/*.wav",
        "locales/*.json",
        "locales/legal/*.json",
        "idm.css",
        "preview.html",
        "preview.js",
        "lib/hls.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "bugi_kafa.png",
      "48": "bugi_kafa.png",
      "128": "bugi_kafa.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["i18n.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ]
}