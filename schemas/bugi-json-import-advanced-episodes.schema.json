{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bugi-local/schemas/bugi-json-import-advanced-episodes.schema.json",
  "title": "Bugi JSON içe aktarma — gelişmiş episodes (Anizium uyumlu)",
  "description": "Kök nesne; episodes dizisi. x-bugi-extract ile alan yolları bu dosyada tanımlıdır; eklenti sadece modu yorumlar.",
  "type": "object",
  "x-bugi-extract": {
    "mode": "nestedEpisodes",
    "episodesPath": "episodes",
    "episode": {
      "seasonKey": "season",
      "episodeKey": "episode",
      "titleKey": "title"
    },
    "sources": {
      "containersPath": "groups",
      "languageFromKey": "group",
      "languageLabelKey": "name",
      "variantsPath": "items",
      "urlKey": "link",
      "qualityKey": "quality"
    },
    "subtitles": {
      "listPath": "subtitles",
      "groupKey": "group",
      "nameKey": "name",
      "linkKey": "link"
    }
  },
  "required": ["episodes"],
  "additionalProperties": true,
  "properties": {
    "episodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/episode" }
    }
  },
  "definitions": {
    "qualityItem": {
      "type": "object",
      "description": "Tek kalite varyantı; link genelde HLS master veya medya playlist URL'si.",
      "required": ["link"],
      "additionalProperties": true,
      "properties": {
        "quality": {
          "type": ["integer", "string"],
          "description": "Çözünürlük (ör. 1080); sayı veya rakam içeren string."
        },
        "link": {
          "type": "string",
          "format": "uri",
          "description": "İndirilecek akış URL'si (.m3u8 vb.)."
        }
      }
    },
    "dubGroup": {
      "type": "object",
      "description": "Dil/dublaj grubu; group boşsa eklenti satırı yok sayar.",
      "required": ["group"],
      "additionalProperties": true,
      "properties": {
        "group": { "type": "string", "description": "Dil anahtarı (seçicide kullanılır)." },
        "name": { "type": "string", "description": "Görünen etiket." },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/qualityItem" }
        }
      }
    },
    "subtitleTrack": {
      "type": "object",
      "description": "Altyazı; group dolu olmalı ki seçicide görünsün. link zorunlu.",
      "required": ["link"],
      "additionalProperties": true,
      "properties": {
        "group": { "type": "string" },
        "name": { "type": "string" },
        "link": { "type": "string", "format": "uri" }
      }
    },
    "episode": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "season": { "type": ["integer", "string"], "default": 1 },
        "episode": { "type": ["integer", "string"], "default": 1 },
        "title": { "type": "string" },
        "groups": {
          "type": "array",
          "items": { "$ref": "#/definitions/dubGroup" }
        },
        "subtitles": {
          "type": "array",
          "items": { "$ref": "#/definitions/subtitleTrack" }
        }
      }
    }
  }
}
